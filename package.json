{
  "name": "react-native-incoming-call",
  "version": "0.1.0",
  "description": "incoming-call",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native-incoming-call-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "nitrogen",
    "nitro.json",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-incoming-call-example",
    "docs:dev": "yarn workspace react-native-incoming-call-docs docs:dev",
    "docs:build": "yarn workspace react-native-incoming-call-docs docs:build",
    "docs:preview": "yarn workspace react-native-incoming-call-docs docs:preview",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "nitrogen": "nitrogen",
    "typecheck": "tsc",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t-kiattisak/react-native-incoming-call.git"
  },
  "author": "t.kiattisak.j <t.kiattisak.j@gmail.com> (https://github.com/t-kiattisak)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/t-kiattisak/react-native-incoming-call/issues"
  },
  "homepage": "https://github.com/t-kiattisak/react-native-incoming-call#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.85.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "nitrogen": "^0.36.1",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.43.0",
    "react-native-nitro-modules": "^0.36.1",
    "release-it": "^20.2.1",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "^0.36.1"
  },
  "workspaces": [
    "example",
    "docs"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "custom",
        {
          "script": "nitrogen",
          "clean": "nitrogen/"
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "type": "nitro-module",
    "languages": "kotlin-swift",
    "tools": [],
    "version": "0.63.0"
  }
}
